{
  "expo": {
    "name": "NotMyRoad",
    "slug": "nmr-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nmr-mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080808"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#080808"
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "backgroundColor": "#080808"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "NotMyRoad uses your location to tag road issue reports within Delhi.",
          "locationWhenInUsePermission": "NotMyRoad uses your location to tag road issue reports within Delhi."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
